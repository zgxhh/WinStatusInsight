{
  "name": "win-status-insight",
  "version": "2.1.0",
  "description": "Windows local status analysis desktop tool",
  "author": "WinStatusInsight",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n API,WEB -c cyan,green \"node server/index.js\" \"vite --host 127.0.0.1\"",
    "server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "electron:dev": "npm run build && electron .",
    "icon:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-icon.ps1",
    "package:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run package:win:installer",
    "package:win:installer": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& npm run icon:win && npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "cn.zgxhh.winstatusinsight",
    "productName": "WinStatusInsight",
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "build/icon-256.png",
        "to": "build/icon-256.png"
      }
    ],
    "win": {
      "icon": "build/icon-256.png",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WinStatusInsight",
      "artifactName": "WinStatusInsight-Setup-${version}.exe"
    }
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "concurrently": "^9.2.1",
    "echarts": "^6.0.0",
    "element-plus": "^2.12.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "lucide-vue-next": "^0.554.0",
    "vite": "^7.2.2",
    "vue": "^3.5.24",
    "vue-echarts": "^8.0.1"
  }
}
